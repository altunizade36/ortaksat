{
  "expo": {
    "name": "OrtakSat",
    "slug": "ortaksat-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ortaksat",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.ortaksat.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:ortaksat.com",
        "applinks:www.ortaksat.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "OrtakSat ilan fotoğrafı seçmek için galeri erişimi ister.",
        "NSCameraUsageDescription": "OrtakSat, ilan fotoğrafını doğrudan çekebilmen için kamera erişimi ister."
      }
    },
    "android": {
      "package": "com.ortaksat.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#ECFEFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ortaksat.com",
              "pathPrefix": "/i"
            },
            {
              "scheme": "https",
              "host": "ortaksat.com",
              "pathPrefix": "/listing"
            },
            {
              "scheme": "https",
              "host": "ortaksat.com",
              "pathPrefix": "/onay"
            },
            {
              "scheme": "https",
              "host": "www.ortaksat.com",
              "pathPrefix": "/i"
            },
            {
              "scheme": "https",
              "host": "www.ortaksat.com",
              "pathPrefix": "/listing"
            },
            {
              "scheme": "https",
              "host": "www.ortaksat.com",
              "pathPrefix": "/onay"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": {
            "web": true,
            "default": false
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "OrtakSat ilan fotoğrafı seçmek için galeri erişimi ister.",
          "cameraPermission": "OrtakSat, ilan fotoğrafını doğrudan çekebilmen için kamera erişimi ister."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-mascot.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ECFEFF"
        }
      ],
      "expo-localization",
      "expo-video",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0EA5B7"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "extra": {
      "privacyUrl": "https://www.ortaksat.com/gizlilik-politikasi",
      "supportUrl": "https://www.ortaksat.com/iletisim",
      "termsUrl": "https://www.ortaksat.com/kullanim-sartlari",
      "eas": {
        "projectId": "replace-after-eas-init"
      }
    }
  }
}