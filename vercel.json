{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist-web",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.ortaksat.com" }],
      "destination": "https://ortaksat.com/",
      "permanent": false
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "www.ortaksat.com" }],
      "destination": "https://ortaksat.com/:path+",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/i/:slug", "destination": "/i/[slug]" },
    { "source": "/blog/:slug", "destination": "/blog/[slug]" },
    { "source": "/listing/:id", "destination": "/listing/[id]" },
    { "source": "/kategori/:slug/:sehir", "destination": "/kategori/[slug]/[sehir]" },
    { "source": "/kategori/:slug", "destination": "/kategori/[slug]" },
    { "source": "/listing-edit/:id", "destination": "/listing-edit/[id]" },
    { "source": "/chat/:id", "destination": "/chat/[id]" },
    { "source": "/store/:id", "destination": "/store/[id]" },
    { "source": "/explore-feed/:id", "destination": "/explore-feed/[id]" }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ]
}
