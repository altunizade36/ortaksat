{
  "name": "ortaksat-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo start --android",
    "android:clear": "expo start --android --clear",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "check:encoding": "node scripts/check-encoding.mjs",
    "quality": "npm run check:encoding && npm run typecheck && npm run doctor",
    "export:android": "expo export --platform android --output-dir dist-check-android",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "build:web": "node scripts/gen-og-maps.mjs && node scripts/generate-sitemap.mjs && expo export --platform web --output-dir dist-web && node scripts/post-export.mjs",
    "serve:web": "npx http-server dist-web -p 8099 -s",
    "doctor": "npx expo-doctor",
    "build:android:preview": "eas build -p android --profile preview",
    "build:ios:preview": "eas build -p ios --profile preview",
    "build:internal": "eas build --profile preview",
    "build:android": "eas build -p android --profile production",
    "build:ios": "eas build -p ios --profile production",
    "submit:android": "eas submit -p android --profile production",
    "submit:ios": "eas submit -p ios --profile production",
    "db:migrate": "node scripts/apply-supabase-migration.mjs",
    "db:apply-all": "node scripts/apply-all.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.107.0",
    "expo": "~54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.1.10",
    "pg": "^8.21.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "expo"
      ]
    }
  },
  "private": true
}
